{
  "name": "frontend",
  "main": "./index.ts",
  "version": "1.0.0",
  "scripts": {
    "prestart": "node ../scripts/check-apple-secret-expiry.js",
    "start": "expo start --dev-client --clear",
    "dev": "expo start --dev-client",
    "build:dev": "cross-env EAS_NO_VCS=1 APP_VARIANT=development eas build --profile development --platform android",
    "build:ios": "cross-env EAS_NO_VCS=1 APP_VARIANT=development eas build --profile development --platform ios",
    "build:all": "cross-env EAS_NO_VCS=1 APP_VARIANT=development eas build --profile development --platform all",
    "ship": "node ../scripts/version-manager.js ship",
    "ship:rebuild": "node ../scripts/check-git-clean.js && rimraf android ios && cross-env EAS_NO_VCS=1 eas build --profile preview --platform all --clear-cache",
    "ship:rebuild:android": "node ../scripts/check-git-clean.js && rimraf android && cross-env EAS_NO_VCS=1 eas build --profile preview --platform android --clear-cache",
    "ship:rebuild:ios": "node ../scripts/check-git-clean.js && rimraf ios && cross-env EAS_NO_VCS=1 eas build --profile preview --platform ios --clear-cache",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "generate:apple-secret": "node ../scripts/generate-apple-secret.js",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
