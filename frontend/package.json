    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.81.1",
    "expo": "~54.0.32",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.6",
    "expo-av": "~16.0.8",
